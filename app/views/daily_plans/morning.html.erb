<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Morning Planning</h2>
    <p class="text-sm text-gray-500 mb-6"><%= @date.strftime("%A, %b %-d, %Y") %></p>

    <!-- Step 1: Review yesterday -->
    <% if @yesterday_tasks.any? %>
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">Yesterday's tasks</h3>
        <div class="space-y-1">
          <% @yesterday_tasks.each do |task| %>
            <div class="flex items-center gap-2 text-sm">
              <% if task.done? %>
                <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-gray-500 line-through"><%= task.title %></span>
              <% else %>
                <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="2"/></svg>
                <span class="text-gray-800"><%= task.title %></span>
                <%= button_to schedule_task_path(task, date: @date), method: :post, class: "text-xs text-indigo-600 hover:text-indigo-800" do %>
                  Move to today
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Step 2: Pull from backlog -->
    <% if @backlog_tasks.any? %>
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">Pull from backlog</h3>
        <div class="space-y-1">
          <% @backlog_tasks.each do |task| %>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-gray-800 flex-1"><%= task.title %></span>
              <%= button_to schedule_task_path(task, date: @date), method: :post, class: "text-xs text-indigo-600 hover:text-indigo-800" do %>
                Add to today
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Complete planning -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", day_path(date: @date), class: "text-sm text-gray-500 hover:text-gray-700" %>
      <%= button_to "Complete Planning", morning_plan_path(date: @date), method: :post, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>
</div>
