<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Daily Shutdown</h2>
    <p class="text-sm text-gray-500 mb-6"><%= @date.strftime("%A, %b %-d, %Y") %></p>

    <!-- Summary -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="bg-green-50 rounded-lg p-3 text-center">
        <p class="text-2xl font-bold text-green-700"><%= @tasks.done.count %></p>
        <p class="text-xs text-green-600">Completed</p>
      </div>
      <div class="bg-amber-50 rounded-lg p-3 text-center">
        <p class="text-2xl font-bold text-amber-700"><%= @tasks.not_done.count %></p>
        <p class="text-xs text-amber-600">Remaining</p>
      </div>
      <div class="bg-blue-50 rounded-lg p-3 text-center">
        <p class="text-2xl font-bold text-blue-700"><%= @tasks.sum(:actual_minutes) %>m</p>
        <p class="text-xs text-blue-600">Time logged</p>
      </div>
    </div>

    <!-- Incomplete tasks -->
    <% incomplete = @tasks.not_done %>
    <% if incomplete.any? %>
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">What to do with remaining tasks?</h3>
        <div class="flex gap-2 mb-3">
          <%= button_to rollover_path(date: @date), method: :post, class: "text-xs px-3 py-1 bg-indigo-50 text-indigo-700 rounded-md hover:bg-indigo-100" do %>
            Roll all to tomorrow
          <% end %>
        </div>
        <div class="space-y-1">
          <% incomplete.each do |task| %>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-gray-800 flex-1"><%= task.title %></span>
              <div class="flex gap-1">
                <%= button_to schedule_task_path(task, date: @date + 1), method: :post, class: "text-xs text-indigo-600 hover:text-indigo-800" do %>
                  Tomorrow
                <% end %>
                <%= button_to unschedule_task_path(task), method: :post, class: "text-xs text-gray-500 hover:text-gray-700" do %>
                  Backlog
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Complete -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", day_path(date: @date), class: "text-sm text-gray-500 hover:text-gray-700" %>
      <%= button_to "Complete Shutdown", shutdown_plan_path(date: @date), method: :post, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>
</div>
