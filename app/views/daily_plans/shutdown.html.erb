<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">Daily Shutdown</h2>
      <p class="text-sm text-gray-500 mt-0.5"><%= @date.strftime("%A, %b %-d, %Y") %></p>
    </div>

    <!-- Stats -->
    <div class="px-6 py-4 bg-gray-50/50 border-b border-gray-100 grid grid-cols-3 gap-4">
      <div class="text-center">
        <p class="text-2xl font-bold text-emerald-600"><%= @completed.count %></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-wider">Completed</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-amber-600"><%= @incomplete.count %></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-wider">Remaining</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-indigo-600"><%= @tasks.sum(:actual_minutes) %><span class="text-sm font-normal text-gray-400">m</span></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-wider">Time logged</p>
      </div>
    </div>

    <!-- Completed tasks -->
    <% if @completed.any? %>
      <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="text-xs font-semibold text-emerald-600 uppercase tracking-widest mb-3">Completed</h3>
        <div class="space-y-2">
          <% @completed.each do |task| %>
            <div class="flex items-center gap-2.5 text-sm">
              <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-gray-500 line-through flex-1"><%= task.title %></span>
              <% if task.channel %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>"><%= task.channel.name %></span>
              <% end %>
              <% if task.actual_minutes > 0 %>
                <span class="text-xs text-gray-400 tabular-nums"><%= task.actual_minutes %>m</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Incomplete tasks -->
    <% if @incomplete.any? %>
      <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="text-xs font-semibold text-amber-600 uppercase tracking-widest mb-2">Not completed</h3>
        <p class="text-xs text-gray-400 mb-3">These will automatically roll over to tomorrow when you complete the shutdown.</p>
        <div class="space-y-2">
          <% @incomplete.each do |task| %>
            <div class="flex items-center gap-2.5 text-sm">
              <div class="w-5 h-5 rounded-full border-2 border-gray-300 shrink-0"></div>
              <span class="text-gray-800 flex-1"><%= task.title %></span>
              <% if task.channel %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>"><%= task.channel.name %></span>
              <% end %>
              <% if task.rollover_count > 0 %>
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-orange-100 text-orange-600" title="Rolling over for <%= task.rollover_count %> days">
                  <%= task.rollover_count %>d
                </span>
              <% end %>
              <div class="flex gap-1 shrink-0">
                <%= button_to unschedule_task_path(task), method: :post, class: "text-[11px] text-gray-400 hover:text-gray-600 px-1.5 py-0.5 rounded hover:bg-gray-100 transition-colors" do %>
                  Backlog
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @incomplete.empty? && @completed.any? %>
      <div class="px-6 py-6 text-center border-b border-gray-100">
        <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-2">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <p class="text-sm font-medium text-emerald-700">All tasks completed!</p>
      </div>
    <% end %>

    <!-- Actions -->
    <div class="px-6 py-4 flex items-center justify-between">
      <%= link_to "Cancel", day_path(date: @date), class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
      <%= button_to shutdown_plan_path(date: @date), method: :post,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 shadow-sm shadow-indigo-200 transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        Complete Shutdown<%= " & Roll #{@incomplete.count} to tomorrow" if @incomplete.any? %>
      <% end %>
    </div>
  </div>

  <!-- Previous shutdowns history -->
  <% past_plans = current_user.daily_plans.where(shutdown_completed: true).where.not(plan_date: @date).order(plan_date: :desc).limit(7) %>
  <% if past_plans.any? %>
    <div class="mt-6">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 px-1">Recent Shutdowns</h3>
      <div class="space-y-2">
        <% past_plans.each do |plan| %>
          <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm px-5 py-3">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-gray-700"><%= plan.plan_date.strftime("%a, %b %-d") %></span>
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span class="text-emerald-600 font-medium"><%= plan.tasks_completed %> done</span>
                <% if plan.tasks_rolled_over > 0 %>
                  <span class="text-amber-600 font-medium"><%= plan.tasks_rolled_over %> rolled</span>
                <% end %>
                <% if plan.total_actual_min > 0 %>
                  <span><%= plan.total_actual_min %>m logged</span>
                <% end %>
              </div>
            </div>

            <% if plan.completed_snapshot.present? %>
              <div class="space-y-0.5">
                <% plan.completed_snapshot.each do |snap| %>
                  <div class="flex items-center gap-1.5 text-xs text-gray-400">
                    <svg class="w-3 h-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="line-through"><%= snap["title"] %></span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <% if plan.rolled_snapshot.present? %>
              <div class="space-y-0.5 mt-1">
                <% plan.rolled_snapshot.each do |snap| %>
                  <div class="flex items-center gap-1.5 text-xs text-gray-400">
                    <svg class="w-3 h-3 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/></svg>
                    <span><%= snap["title"] %></span>
                    <% if snap["rollover_count"].to_i > 1 %>
                      <span class="text-[9px] font-bold px-1 py-0 rounded bg-orange-100 text-orange-500"><%= snap["rollover_count"] %>d</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
