<div class="max-w-xl mx-auto space-y-6">
  <h2 class="text-lg font-semibold text-gray-900">Settings</h2>

  <!-- Profile -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-indigo-500/20 shrink-0">
        <%= current_user.email[0].upcase %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.email %></p>
        <p class="text-xs text-gray-400">Member since <%= current_user.created_at.strftime("%b %Y") %></p>
      </div>
    </div>
  </div>

  <!-- Preferences -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-4">Preferences</h3>
    <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Timezone</label>
        <%= f.select :timezone, ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.name] },
            {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Daily target</label>
          <div class="relative">
            <%= f.number_field :daily_hour_target, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm pr-10", min: 0, step: 30 %>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400">min</span>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Work</label>
          <div class="relative">
            <%= f.number_field :pomodoro_work_min, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm pr-10", min: 1 %>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400">min</span>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Break</label>
          <div class="relative">
            <%= f.number_field :pomodoro_break_min, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm pr-10", min: 1 %>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400">min</span>
          </div>
        </div>
      </div>

      <%= f.submit "Save", class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 cursor-pointer transition-colors" %>
    <% end %>
  </div>

  <!-- API Token -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-1">API Access</h3>
    <p class="text-xs text-gray-400 mb-3">Use this token for API and MCP integrations.</p>
    <div class="flex items-center gap-2">
      <div class="flex-1 relative overflow-hidden rounded-lg border border-gray-200 bg-gray-50 cursor-pointer"
           onclick="const c=this.querySelector('code'),o=this.querySelector('.overlay');if(c.style.filter){c.style.filter='';o.style.opacity='0'}else{c.style.filter='blur(4px)';o.style.opacity='1'}">
        <code class="text-xs p-2.5 block break-all font-mono text-gray-600 select-all" style="filter:blur(4px)"><%= current_user.api_token %></code>
        <div class="overlay absolute inset-0 flex items-center justify-center bg-gray-50/60 transition-opacity">
          <span class="text-xs text-gray-500 font-medium flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            Click to reveal
          </span>
        </div>
      </div>
      <button type="button"
              onclick="navigator.clipboard.writeText('<%= current_user.api_token %>');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)"
              class="px-3 py-2.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-colors shrink-0">Copy</button>
    </div>
  </div>

  <!-- Obsidian Integration -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-1">Obsidian Integration</h3>
    <p class="text-xs text-gray-400 mb-4">Connect a LLM to organize content and send it to your Obsidian vault.</p>

    <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">LLM Endpoint</label>
          <%= f.text_field :llm_endpoint,
              placeholder: "http://localhost:11434/v1/chat/completions",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
          <p class="text-[11px] text-gray-400 mt-1">Any OpenAI-compatible API (Ollama, OpenAI, Anthropic, etc.)</p>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Model</label>
          <%= f.text_field :llm_model,
              placeholder: "llama3, gpt-4o, claude-sonnet-4-6...",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">API Key</label>
          <%= f.password_field :llm_api_key,
              value: @user.llm_api_key,
              placeholder: "Optional for local models",
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Obsidian Vault Path</label>
        <%= f.text_field :obsidian_vault_path,
            placeholder: "/Users/you/Documents/MyVault",
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
        <% if @user.obsidian_vault_path.present? && !Dir.exist?(@user.obsidian_vault_path.to_s) %>
          <p class="text-[11px] text-red-500 mt-1">Directory not found</p>
        <% elsif @user.obsidian_vault_path.present? %>
          <p class="text-[11px] text-emerald-500 mt-1">Vault found</p>
        <% end %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Response Format</label>
        <%= f.select :obsidian_response_format,
            [["JSON (structured — LLM returns title, folder, tags, body)", "json"],
             ["Raw Markdown (LLM returns the final .md file)", "raw_markdown"]],
            {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Prompt Template</label>
        <%= f.text_area :obsidian_prompt_template,
            rows: 10,
            placeholder: Obsidian::Processor::DEFAULT_PROMPT.strip,
            class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-xs font-mono resize-y" %>
        <p class="text-[11px] text-gray-400 mt-1">
          Variables: <code class="bg-gray-100 px-1 rounded">{{content}}</code>
          <code class="bg-gray-100 px-1 rounded">{{source}}</code>
          <code class="bg-gray-100 px-1 rounded">{{channel}}</code>
          <code class="bg-gray-100 px-1 rounded">{{context}}</code>
          <code class="bg-gray-100 px-1 rounded">{{date}}</code>
        </p>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "Save", class: "px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 cursor-pointer transition-colors" %>

        <% if @user.llm_endpoint.present? && @user.llm_model.present? %>
          <%= button_to "Test LLM Connection", obsidian_test_path,
              method: :post,
              class: "px-4 py-2 text-sm font-medium text-purple-600 border border-purple-200 rounded-lg hover:bg-purple-50 transition-colors cursor-pointer",
              data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
    <% end %>

    <div id="obsidian-test-result"></div>
  </div>

  <!-- Google Calendar -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Google Calendar</h3>
    <% integrations = current_user.calendar_integrations.where(provider: "google", active: true) %>

    <% if integrations.any? %>
      <div class="space-y-3 mb-3">
        <% integrations.each do |integration| %>
          <div class="rounded-lg border border-emerald-200 bg-emerald-50/50 p-4">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
                <span class="text-sm font-medium text-gray-800"><%= integration.google_email || "Connected" %></span>
              </div>
              <% if integration.last_synced_at %>
                <span class="text-[11px] text-gray-400"><%= time_ago_in_words(integration.last_synced_at) %> ago</span>
              <% end %>
            </div>

            <p class="text-xs text-gray-500 mb-3"><%= integration.calendar_ids.size %> calendars &middot; <%= integration.calendar_events.count %> events</p>

            <div class="flex gap-2 mb-3">
              <%= button_to "Sync now", sync_google_calendar_path(integration), method: :post, class: "text-xs px-3 py-1.5 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors" %>
              <%= button_to "Disconnect", disconnect_google_calendar_path(integration), method: :delete,
                  class: "text-xs px-3 py-1.5 text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition-colors",
                  data: { turbo_confirm: "Disconnect #{integration.google_email}?" } %>
            </div>

            <% if integration.calendar_metadata.present? %>
              <details>
                <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-700"><%= integration.calendar_ids.size %> calendars</summary>
                <div class="mt-2 grid grid-cols-2 gap-1">
                  <% (integration.calendar_metadata || {}).each do |cal_id, meta| %>
                    <div class="flex items-center gap-1.5 text-xs text-gray-500 truncate">
                      <div class="w-2 h-2 rounded-sm shrink-0" style="background-color: <%= meta['color'] || '#4285F4' %>"></div>
                      <span class="truncate"><%= meta['summary'] || cal_id.truncate(30) %></span>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>
          </div>
        <% end %>
      </div>

      <p class="text-xs text-gray-400 mb-3">Auto-syncs every 15 minutes.</p>
    <% end %>

    <% if GoogleCalendar::Client.configured? %>
      <%= link_to auth_google_calendar_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-sm font-medium rounded-lg hover:bg-gray-50 shadow-sm transition-colors" do %>
        <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        <%= integrations.any? ? "Connect another account" : "Connect Google Calendar" %>
      <% end %>
    <% elsif integrations.empty? %>
      <div class="rounded-lg bg-amber-50 border border-amber-200 p-3">
        <p class="text-sm text-amber-700">Google Calendar not configured.</p>
        <p class="text-xs text-amber-600 mt-1">Set <code class="bg-amber-100 px-1 rounded">GOOGLE_CLIENT_ID</code> and <code class="bg-amber-100 px-1 rounded">GOOGLE_CLIENT_SECRET</code> in your environment.</p>
      </div>
    <% end %>
  </div>
</div>
