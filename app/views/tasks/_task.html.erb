<turbo-frame id="<%= dom_id(task) %>" data-controller="subtask-add">
  <div class="flex items-center gap-2.5 group px-4 py-3 transition-colors duration-150 hover:bg-gray-50/80 <%= 'opacity-60' if task.done? %>"
       data-task-id="<%= task.id %>">
    <!-- Checkbox -->
    <% if task.done? %>
      <%= button_to reopen_task_path(task), method: :post, class: "shrink-0 transition-transform hover:scale-110", form: { data: { turbo_frame: "_top" } } do %>
        <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center">
          <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
      <% end %>
    <% else %>
      <%= button_to complete_task_path(task), method: :post, class: "shrink-0 transition-transform hover:scale-110", form: { data: { turbo_frame: "_top" } } do %>
        <div class="w-5 h-5 rounded-full border-2 border-gray-300 hover:border-emerald-400 transition-colors"></div>
      <% end %>
    <% end %>

    <!-- Title -->
    <div class="flex-1 min-w-0">
      <%= link_to task.title, task_path(task),
          class: "text-sm font-medium transition-colors duration-150 #{task.done? ? 'line-through text-gray-400' : 'text-gray-700 hover:text-indigo-600'}",
          data: { turbo_frame: "_top" } %>
    </div>

    <!-- Meta badges -->
    <div class="flex items-center gap-1.5 shrink-0">
      <% if task.channel %>
        <span class="text-[11px] font-medium px-2 py-0.5 rounded-full whitespace-nowrap" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>">
          <%= task.channel.name %>
        </span>
      <% end %>

      <% if task.weekly_objective %>
        <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-indigo-50 text-indigo-500 whitespace-nowrap" title="<%= task.weekly_objective.title %>">
          <svg class="w-2.5 h-2.5 inline -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </span>
      <% end %>

      <% if task.planned_minutes && task.planned_minutes > 0 %>
        <span class="text-[11px] text-gray-400 font-medium tabular-nums"><%= task.planned_minutes %>m</span>
      <% end %>

      <% if task.priority > 0 %>
        <% pclass = task.priority == 3 ? 'bg-red-100 text-red-600' : task.priority == 2 ? 'bg-amber-100 text-amber-600' : 'bg-blue-100 text-blue-500' %>
        <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= pclass %>">
          <%= task.priority == 3 ? 'HIGH' : task.priority == 2 ? 'MED' : 'LOW' %>
        </span>
      <% end %>

      <% if task.rollover_count > 0 %>
        <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-orange-100 text-orange-600" title="Rolling over for <%= task.rollover_count %> consecutive days">
          <%= task.rollover_count %>d
        </span>
      <% end %>

      <!-- Subtask count -->
      <% if !task.subtask? && task.subtasks.any? %>
        <span class="text-[11px] text-gray-400 font-medium tabular-nums" title="<%= task.subtasks.done.count %>/<%= task.subtasks.count %> subtasks done">
          <svg class="w-3 h-3 inline -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/></svg>
          <%= task.subtasks.done.count %>/<%= task.subtasks.count %>
        </span>
      <% end %>
    </div>

    <!-- Actions (visible on hover) -->
    <div class="hidden group-hover:flex items-center gap-0.5 shrink-0">
      <!-- Play timer button -->
      <% unless task.done? %>
        <%= button_to timer_start_path(task_id: task.id), method: :post,
            class: "p-1.5 rounded-lg hover:bg-emerald-50 transition-colors", title: "Start timer",
            form: { data: { turbo_frame: "_top" } } do %>
          <svg class="w-3.5 h-3.5 text-gray-400 hover:text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <% end %>
      <% end %>

      <!-- Add subtask button (only for top-level tasks) -->
      <% unless task.subtask? || task.done? %>
        <button type="button"
                class="p-1.5 rounded-lg hover:bg-indigo-50 transition-colors"
                title="Add subtask"
                data-action="click->subtask-add#toggle">
          <svg class="w-3.5 h-3.5 text-gray-400 hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
        </button>
      <% end %>

      <% unless task.done? %>
        <% if task.backlog? %>
          <%= button_to schedule_task_path(task, date: Date.current), method: :post,
              class: "p-1.5 rounded-lg hover:bg-indigo-50 transition-colors", title: "Schedule today",
              form: { data: { turbo_frame: "_top" } } do %>
            <svg class="w-3.5 h-3.5 text-gray-400 hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <% end %>
        <% else %>
          <%= button_to unschedule_task_path(task), method: :post,
              class: "p-1.5 rounded-lg hover:bg-gray-100 transition-colors", title: "Move to backlog",
              form: { data: { turbo_frame: "_top" } } do %>
            <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          <% end %>
        <% end %>
      <% end %>

      <%= button_to task_path(task), method: :delete,
          class: "p-1.5 rounded-lg hover:bg-red-50 transition-colors", title: "Delete",
          data: { turbo_confirm: "Delete this task?" },
          form: { data: { turbo_frame: "_top" } } do %>
        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      <% end %>
    </div>
  </div>

  <!-- Inline subtask add form (hidden by default) -->
  <% unless task.subtask? %>
    <div class="hidden ml-11 border-l-2 border-indigo-200 px-4 py-2 bg-indigo-50/30" data-subtask-add-target="form">
      <%= form_with model: Task.new, url: tasks_path, class: "flex items-center gap-2", data: { action: "turbo:submit-end->subtask-add#afterSubmit" } do |f| %>
        <%= f.hidden_field :parent_task_id, value: task.id %>
        <%= f.hidden_field :scheduled_date, value: task.scheduled_date %>
        <%= f.hidden_field :channel_id, value: task.channel_id %>
        <div class="w-4 h-4 rounded-full border-2 border-dashed border-gray-300 shrink-0"></div>
        <%= f.text_field :title,
            placeholder: "Add subtask...",
            class: "flex-1 text-xs border-0 focus:ring-0 py-0 px-0 placeholder-gray-400 text-gray-700 bg-transparent",
            data: { subtask_add_target: "input" },
            autocomplete: "off" %>
        <%= f.submit "Add", class: "text-[10px] font-semibold text-indigo-500 hover:text-indigo-700 cursor-pointer uppercase tracking-wide" %>
        <button type="button" class="text-[10px] text-gray-400 hover:text-gray-600" data-action="click->subtask-add#toggle">Cancel</button>
      <% end %>
    </div>
  <% end %>

  <!-- Subtasks -->
  <div id="subtasks_<%= task.id %>" class="<%= 'ml-11 border-l-2 border-gray-100' if task.subtasks.any? %>">
    <% task.subtasks.ordered.each do |subtask| %>
      <%= render "tasks/task", task: subtask %>
    <% end %>
  </div>
</turbo-frame>
