<div class="max-w-2xl mx-auto">
  <div class="mb-4">
    <%= link_to "&larr; Back".html_safe, :back, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="flex items-center gap-3 mb-4">
      <% if @task.done? %>
        <svg class="w-6 h-6 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <% end %>
      <h1 class="text-xl font-semibold text-gray-900 <%= 'line-through text-gray-400' if @task.done? %>"><%= @task.title %></h1>
    </div>

    <div class="flex flex-wrap gap-3 text-sm text-gray-500 mb-4">
      <% if @task.channel %>
        <span class="px-2 py-0.5 rounded-full text-xs" style="background-color: <%= @task.channel.color %>20; color: <%= @task.channel.color %>"><%= @task.channel.name %></span>
      <% end %>
      <% if @task.scheduled_date %>
        <span>Scheduled: <%= @task.scheduled_date.strftime("%b %-d, %Y") %></span>
      <% else %>
        <span>Backlog</span>
      <% end %>
      <% if @task.planned_minutes && @task.planned_minutes > 0 %>
        <span>~<%= @task.planned_minutes %>m planned</span>
      <% end %>
      <% if @task.actual_minutes > 0 %>
        <span><%= @task.actual_minutes %>m logged</span>
      <% end %>
    </div>

    <% if @task.notes.present? %>
      <div class="prose prose-sm max-w-none mb-4 border-t border-gray-100 pt-4">
        <%= @task.notes %>
      </div>
    <% end %>

    <!-- Subtasks -->
    <% if @subtasks.any? %>
      <div class="border-t border-gray-100 pt-4">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">Subtasks</h3>
        <div class="space-y-1">
          <% @subtasks.each do |subtask| %>
            <%= render "tasks/task", task: subtask %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex gap-2 mt-6 pt-4 border-t border-gray-100">
      <%= link_to "Edit", edit_task_path(@task), class: "px-3 py-1.5 text-sm bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200" %>
      <% unless @task.done? %>
        <%= button_to "Complete", complete_task_path(@task), method: :post, class: "px-3 py-1.5 text-sm bg-green-50 text-green-700 rounded-md hover:bg-green-100" %>
        <%= button_to "Start Timer", timer_start_path(task_id: @task.id), method: :post, class: "px-3 py-1.5 text-sm bg-indigo-50 text-indigo-700 rounded-md hover:bg-indigo-100" %>
      <% end %>
    </div>
  </div>
</div>
