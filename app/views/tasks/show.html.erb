<div class="max-w-2xl mx-auto">
  <div class="mb-4">
    <%= link_to root_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
      Back
    <% end %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden">
    <!-- Header -->
    <div class="px-6 py-5 border-b border-gray-100">
      <div class="flex items-start gap-3">
        <% if @task.done? %>
          <%= button_to reopen_task_path(@task), method: :post, class: "shrink-0 mt-1" do %>
            <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
          <% end %>
        <% else %>
          <%= button_to complete_task_path(@task), method: :post, class: "shrink-0 mt-1" do %>
            <div class="w-6 h-6 rounded-full border-2 border-gray-300 hover:border-emerald-400 transition-colors"></div>
          <% end %>
        <% end %>
        <div class="flex-1 min-w-0">
          <h1 class="text-lg font-semibold text-gray-900 <%= 'line-through text-gray-400' if @task.done? %>"><%= @task.title %></h1>
          <div class="flex flex-wrap items-center gap-2 mt-2">
            <% if @task.channel %>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background-color: <%= @task.channel.color %>15; color: <%= @task.channel.color %>"><%= @task.channel.name %></span>
            <% end %>
            <% if @task.scheduled_date %>
              <span class="text-xs text-gray-500"><%= @task.scheduled_date.strftime("%b %-d, %Y") %></span>
            <% else %>
              <span class="text-xs text-gray-400 italic">Backlog</span>
            <% end %>
            <% if @task.priority > 0 %>
              <% pclass = @task.priority == 3 ? "bg-red-100 text-red-600" : @task.priority == 2 ? "bg-amber-100 text-amber-600" : "bg-blue-100 text-blue-500" %>
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= pclass %>"><%= @task.priority == 3 ? "HIGH" : @task.priority == 2 ? "MED" : "LOW" %></span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="px-6 py-3 bg-gray-50/50 border-b border-gray-100 flex gap-6">
      <div class="text-center">
        <p class="text-lg font-semibold text-gray-700"><%= @task.planned_minutes || 0 %><span class="text-xs font-normal text-gray-400">m</span></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-wider">Planned</p>
      </div>
      <div class="text-center">
        <p class="text-lg font-semibold text-gray-700"><%= @task.actual_minutes %><span class="text-xs font-normal text-gray-400">m</span></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-wider">Logged</p>
      </div>
      <% if @task.due_date %>
        <div class="text-center">
          <p class="text-sm font-semibold <%= @task.overdue? ? 'text-red-600' : 'text-gray-700' %>"><%= @task.due_date.strftime("%b %-d") %></p>
          <p class="text-[10px] text-gray-400 uppercase tracking-wider">Due</p>
        </div>
      <% end %>
    </div>

    <!-- Notes -->
    <div class="px-6 py-4">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Notes</h3>
      <% if @task.notes.body.present? %>
        <div class="prose prose-sm max-w-none text-gray-700">
          <%= @task.notes %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 italic">No notes yet. <%= link_to "Add notes", edit_task_path(@task), class: "text-indigo-500 hover:text-indigo-700" %></p>
      <% end %>
    </div>

    <!-- Subtasks -->
    <% if @subtasks.any? %>
      <div class="px-6 py-4 border-t border-gray-100">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Subtasks</h3>
        <div class="space-y-1">
          <% @subtasks.each do |subtask| %>
            <%= render "tasks/task", task: subtask %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Actions -->
    <div class="px-6 py-4 border-t border-gray-100 flex flex-wrap gap-2">
      <%= link_to edit_task_path(@task), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
      <% unless @task.done? %>
        <%= button_to complete_task_path(@task), method: :post, class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-emerald-50 text-emerald-700 rounded-lg hover:bg-emerald-100 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Complete
        <% end %>
        <%= button_to timer_start_path(task_id: @task.id), method: :post, class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-indigo-50 text-indigo-700 rounded-lg hover:bg-indigo-100 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><circle cx="12" cy="12" r="10" stroke-width="1.5"/></svg>
          Start Timer
        <% end %>
      <% else %>
        <%= button_to reopen_task_path(@task), method: :post, class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-amber-50 text-amber-700 rounded-lg hover:bg-amber-100 transition-colors" do %>
          Reopen
        <% end %>
      <% end %>
      <%= button_to task_path(@task), method: :delete, data: { turbo_confirm: "Delete this task?" }, class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors ml-auto" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      <% end %>
    </div>
  </div>
</div>
