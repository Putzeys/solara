<%= form_with model: Task.new, url: tasks_path, class: "flex items-center gap-3", data: { controller: "task-quick-add", action: "turbo:submit-end->task-quick-add#reset" } do |f| %>
  <%= f.hidden_field :scheduled_date, value: current_date %>
  <div class="w-5 h-5 rounded-full border-2 border-dashed border-gray-300 shrink-0"></div>
  <%= f.text_field :title,
      placeholder: "What needs to be done?",
      class: "flex-1 text-sm border-0 focus:ring-0 py-0 px-0 placeholder-gray-400 text-gray-700 bg-transparent",
      data: { task_quick_add_target: "input" },
      autocomplete: "off" %>
  <%= f.submit "Add", class: "text-xs font-semibold text-indigo-500 hover:text-indigo-700 cursor-pointer transition-colors uppercase tracking-wide" %>
<% end %>
