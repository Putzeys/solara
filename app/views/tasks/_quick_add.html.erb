<%= form_with model: Task.new, url: tasks_path, class: "flex items-center gap-3 relative",
    data: {
      controller: "task-quick-add",
      action: "turbo:submit-end->task-quick-add#reset"
    } do |f| %>
  <%= f.hidden_field :scheduled_date, value: current_date %>
  <%= f.hidden_field :channel_id, data: { task_quick_add_target: "channelId" } %>
  <div class="w-5 h-5 rounded-full border-2 border-dashed border-gray-300 shrink-0"></div>
  <%= f.text_field :title,
      placeholder: "Add a task... type # for channel",
      class: "flex-1 text-sm border-0 focus:ring-0 py-0 px-0 placeholder-gray-400 text-gray-700 bg-transparent",
      data: { task_quick_add_target: "input", action: "input->task-quick-add#onInput keydown->task-quick-add#onKeydown" },
      autocomplete: "off" %>

  <!-- Channel badge -->
  <span class="hidden text-[11px] font-medium px-2 py-0.5 rounded-full shrink-0" data-task-quick-add-target="channelBadge"></span>

  <%= f.submit "Add", class: "text-xs font-semibold text-indigo-500 hover:text-indigo-700 cursor-pointer transition-colors uppercase tracking-wide" %>

  <!-- Channel dropdown -->
  <div class="hidden absolute left-8 top-full mt-1 w-64 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50 max-h-48 overflow-y-auto"
       data-task-quick-add-target="dropdown">
    <% current_user.channels.active.ordered.each do |channel| %>
      <button type="button"
              class="channel-option w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-colors text-left"
              data-action="click->task-quick-add#selectChannel"
              data-channel-id="<%= channel.id %>"
              data-channel-name="<%= channel.name %>"
              data-channel-color="<%= channel.color %>">
        <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= channel.color %>"></span>
        <span><%= channel.name %></span>
      </button>
    <% end %>
  </div>
<% end %>
