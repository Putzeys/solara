<div class="max-w-xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Contexts</h2>
    <%= link_to "New Context", new_context_path, class: "px-3 py-1.5 text-sm bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
  </div>

  <div class="space-y-2">
    <% @contexts.each do |context| %>
      <div class="bg-white rounded-md border border-gray-200 p-3">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full" style="background-color: <%= context.color %>"></span>
            <span class="text-sm font-medium text-gray-800"><%= context.name %></span>
          </div>
          <div class="flex gap-2">
            <%= link_to "Edit", edit_context_path(context), class: "text-xs text-gray-500 hover:text-gray-700" %>
            <%= button_to "Archive", context_path(context), method: :delete, class: "text-xs text-red-500 hover:text-red-700", data: { turbo_confirm: "Archive?" } %>
          </div>
        </div>
        <% if context.channels.active.any? %>
          <div class="ml-5 text-xs text-gray-500">
            <%= context.channels.active.map(&:name).join(", ") %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
