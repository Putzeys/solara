<div class="max-w-2xl mx-auto space-y-6">
  <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    Obsidian
  </h2>

  <% unless current_user.obsidian_configured? %>
    <div class="rounded-xl border border-amber-200 bg-amber-50/50 p-4">
      <p class="text-sm text-amber-700 font-medium">Obsidian integration not configured</p>
      <p class="text-xs text-amber-600 mt-1">Set your LLM endpoint, model, and vault path in <%= link_to "Settings", settings_path, class: "underline hover:text-amber-800" %>.</p>
    </div>
  <% end %>

  <!-- Quick Capture -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Quick Capture</h3>
    <p class="text-xs text-gray-400 mb-3">Write anything. The LLM will organize and send it to your Obsidian vault.</p>

    <%= form_with url: obsidian_capture_path, method: :post, class: "space-y-3" do |f| %>
      <%= f.text_area :content,
          rows: 5,
          placeholder: "What did you learn? What do you want to remember?",
          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm resize-y" %>

      <div class="flex items-center justify-between">
        <span class="text-xs text-gray-400">Processed by your LLM, saved as markdown</span>
        <%= f.submit "Send to Obsidian",
            class: "px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 cursor-pointer transition-colors disabled:opacity-50",
            disabled: !current_user.obsidian_configured? %>
      </div>
    <% end %>
  </div>

  <!-- Search -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Search Vault</h3>

    <%= form_with url: obsidian_search_path, method: :get, class: "mb-4" do |f| %>
      <div class="flex gap-2">
        <%= f.search_field :q, value: @query,
            placeholder: "Search your knowledge base...",
            class: "flex-1 rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm",
            disabled: !current_user.obsidian_configured?,
            autofocus: @query.present? %>
        <%= f.submit "Search",
            class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 cursor-pointer transition-colors" %>
      </div>
    <% end %>

    <% if @search_error.present? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-3 mb-3">
        <p class="text-sm text-red-700"><%= @search_error %></p>
      </div>
    <% end %>

    <turbo-frame id="obsidian-results">
      <% if @query.present? && @results.present? %>
        <p class="text-xs text-gray-400 mb-3"><%= @results.size %> result<%= @results.size == 1 ? "" : "s" %> for "<%= @query %>"</p>
        <div class="space-y-2">
          <% @results.each do |result| %>
            <div class="rounded-lg border border-gray-100 hover:border-purple-200 p-3 transition-colors group">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate group-hover:text-purple-700 transition-colors">
                    <%= result[:name] %>
                  </p>
                  <p class="text-xs text-gray-400 truncate mt-0.5"><%= result[:path] %></p>
                  <% if result[:snippet].present? %>
                    <p class="text-xs text-gray-500 mt-1.5 line-clamp-2"><%= result[:snippet] %></p>
                  <% end %>
                </div>
                <% vault_name = File.basename(current_user.obsidian_vault_path.to_s) %>
                <a href="obsidian://open?vault=<%= ERB::Util.url_encode(vault_name) %>&file=<%= ERB::Util.url_encode(result[:path].sub(/\.md$/, "")) %>"
                   class="shrink-0 px-2 py-1 text-xs text-purple-600 border border-purple-200 rounded-md hover:bg-purple-50 transition-colors"
                   title="Open in Obsidian">
                  Open
                </a>
              </div>
            </div>
          <% end %>
        </div>
      <% elsif @query.present? %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-400">No results for "<%= @query %>"</p>
        </div>
      <% else %>
        <div class="text-center py-6">
          <svg class="w-8 h-8 text-gray-200 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <p class="text-sm text-gray-400">Search your Obsidian vault</p>
        </div>
      <% end %>
    </turbo-frame>
  </div>
</div>
