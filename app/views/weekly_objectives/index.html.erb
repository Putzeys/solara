<div class="max-w-xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Weekly Objectives</h2>
    <%= link_to "New Objective", new_weekly_objective_path, class: "px-3 py-1.5 text-sm bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
  </div>

  <div class="space-y-2">
    <% @objectives.each do |obj| %>
      <div class="flex items-center justify-between px-3 py-2 bg-white rounded-md border border-gray-200">
        <span class="text-sm text-gray-800"><%= obj.title %></span>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_weekly_objective_path(obj), class: "text-xs text-gray-500 hover:text-gray-700" %>
          <%= button_to "Delete", weekly_objective_path(obj), method: :delete, class: "text-xs text-red-500 hover:text-red-700", data: { turbo_confirm: "Delete?" } %>
        </div>
      </div>
    <% end %>

    <% if @objectives.empty? %>
      <p class="text-sm text-gray-400 py-4 text-center">No objectives for this week</p>
    <% end %>
  </div>
</div>
