<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">Weekly Plan</h2>
      <p class="text-xs text-gray-400 mt-0.5">
        Week of <%= @date.beginning_of_week(:monday).strftime("%b %-d") %> &ndash; <%= @date.end_of_week(:monday).strftime("%b %-d, %Y") %>
      </p>
    </div>
  </div>

  <!-- Inline add -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm px-4 py-3 mb-4">
    <%= form_with model: WeeklyObjective.new, url: weekly_objectives_path, class: "flex items-center gap-3" do |f| %>
      <%= f.hidden_field :week_start_date, value: @date.beginning_of_week(:monday) %>
      <div class="w-5 h-5 rounded-full border-2 border-dashed border-indigo-300 shrink-0 flex items-center justify-center">
        <svg class="w-3 h-3 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </div>
      <%= f.text_field :title,
          placeholder: "Add a weekly objective...",
          class: "flex-1 text-sm border-0 focus:ring-0 py-0 px-0 placeholder-gray-400 text-gray-700 bg-transparent",
          autocomplete: "off" %>
      <%= f.submit "Add", class: "text-xs font-semibold text-indigo-500 hover:text-indigo-700 cursor-pointer transition-colors uppercase tracking-wide" %>
    <% end %>
  </div>

  <!-- Objectives list -->
  <div class="space-y-3">
    <% @objectives.each do |obj| %>
      <% linked_tasks = obj.tasks.where(discarded_at: nil) %>
      <% done_count = linked_tasks.done.count %>
      <% total_count = linked_tasks.count %>
      <% progress = total_count > 0 ? (done_count.to_f / total_count * 100).round : 0 %>

      <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden">
        <!-- Objective header -->
        <div class="px-4 py-3 flex items-center gap-3">
          <% if obj.status == "completed" %>
            <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
          <% else %>
            <div class="w-5 h-5 rounded-full border-2 border-indigo-300 shrink-0"></div>
          <% end %>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-gray-800 <%= 'line-through text-gray-400' if obj.status == 'completed' %>"><%= obj.title %></span>
              <% if total_count > 0 %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full <%= done_count == total_count ? 'bg-emerald-100 text-emerald-600' : 'bg-gray-100 text-gray-500' %>">
                  <%= done_count %>/<%= total_count %>
                </span>
              <% end %>
            </div>
            <% if total_count > 0 %>
              <div class="mt-1.5 h-1 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-300 <%= done_count == total_count ? 'bg-emerald-500' : 'bg-indigo-500' %>" style="width: <%= progress %>%"></div>
              </div>
            <% end %>
          </div>

          <div class="flex items-center gap-1 shrink-0">
            <% if obj.status == "active" %>
              <%= button_to weekly_objective_path(obj, weekly_objective: { status: "completed" }), method: :patch,
                  class: "p-1.5 rounded-lg hover:bg-emerald-50 transition-colors", title: "Complete" do %>
                <svg class="w-3.5 h-3.5 text-gray-400 hover:text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <% end %>
            <% else %>
              <%= button_to weekly_objective_path(obj, weekly_objective: { status: "active" }), method: :patch,
                  class: "p-1.5 rounded-lg hover:bg-amber-50 transition-colors", title: "Reopen" do %>
                <svg class="w-3.5 h-3.5 text-gray-400 hover:text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              <% end %>
            <% end %>
            <%= link_to edit_weekly_objective_path(obj), class: "p-1.5 rounded-lg hover:bg-gray-100 transition-colors", title: "Edit" do %>
              <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <% end %>
            <%= button_to weekly_objective_path(obj), method: :delete,
                class: "p-1.5 rounded-lg hover:bg-red-50 transition-colors", title: "Delete",
                data: { turbo_confirm: "Delete this objective and unlink its tasks?" } do %>
              <svg class="w-3.5 h-3.5 text-gray-400 hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            <% end %>
          </div>
        </div>

        <!-- Linked tasks -->
        <% if linked_tasks.any? %>
          <div class="border-t border-gray-100 px-4 py-2 space-y-1">
            <% linked_tasks.ordered.each do |task| %>
              <div class="flex items-center gap-2 py-1">
                <% if task.done? %>
                  <div class="w-4 h-4 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                    <svg class="w-2.5 h-2.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                <% else %>
                  <div class="w-4 h-4 rounded-full border-2 border-gray-300 shrink-0"></div>
                <% end %>
                <%= link_to task.title, task_path(task),
                    class: "text-xs #{task.done? ? 'line-through text-gray-400' : 'text-gray-600 hover:text-indigo-600'} transition-colors truncate" %>
                <% if task.channel %>
                  <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full shrink-0 ml-auto" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>"><%= task.channel.name %></span>
                <% end %>
                <% if task.scheduled_date %>
                  <span class="text-[10px] text-gray-400 shrink-0"><%= task.scheduled_date.strftime("%a") %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @objectives.empty? %>
      <div class="text-center py-12">
        <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <p class="text-sm font-medium text-gray-500">No objectives for this week</p>
        <p class="text-xs text-gray-400 mt-1">Add one above to start planning your week</p>
      </div>
    <% end %>
  </div>
</div>
