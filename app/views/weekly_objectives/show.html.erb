<div class="max-w-2xl mx-auto">
  <!-- Back -->
  <div class="mb-4">
    <%= link_to weekly_objectives_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
      Weekly Plan
    <% end %>
  </div>

  <% done_count = @tasks.select(&:done?).size %>
  <% total_count = @tasks.size %>
  <% progress = total_count > 0 ? (done_count.to_f / total_count * 100).round : 0 %>

  <!-- Header card -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden mb-4">
    <div class="px-6 py-5">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <div class="flex items-center gap-3">
            <% if @objective.status == "completed" %>
              <div class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
            <% else %>
              <div class="w-7 h-7 rounded-full border-2 border-indigo-400 shrink-0"></div>
            <% end %>
            <h1 class="text-lg font-semibold text-gray-900 <%= 'line-through text-gray-400' if @objective.status == 'completed' %>"><%= @objective.title %></h1>
          </div>
          <p class="text-xs text-gray-400 mt-2 ml-10">
            Week of <%= @objective.week_start_date.strftime("%b %-d") %> &ndash; <%= (@objective.week_start_date + 6).strftime("%b %-d, %Y") %>
          </p>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_weekly_objective_path(@objective), class: "p-2 rounded-lg hover:bg-gray-100 transition-colors" do %>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <% end %>
        </div>
      </div>

      <!-- Progress -->
      <% if total_count > 0 %>
        <div class="mt-4 ml-10">
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs text-gray-500"><%= done_count %> of <%= total_count %> tasks completed</span>
            <span class="text-xs font-medium <%= progress == 100 ? 'text-emerald-600' : 'text-indigo-600' %>"><%= progress %>%</span>
          </div>
          <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500 <%= progress == 100 ? 'bg-emerald-500' : 'bg-indigo-500' %>" style="width: <%= progress %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Linked tasks -->
  <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden mb-4">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Linked tasks</h3>
      <span class="text-xs text-gray-400"><%= total_count %> tasks</span>
    </div>

    <% if @tasks.any? %>
      <div class="divide-y divide-gray-50">
        <% @tasks.each do |task| %>
          <div class="flex items-center gap-3 px-5 py-3 group hover:bg-gray-50/50 transition-colors">
            <% if task.done? %>
              <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
            <% else %>
              <div class="w-5 h-5 rounded-full border-2 border-gray-300 shrink-0"></div>
            <% end %>

            <%= link_to task.title, task_path(task),
                class: "flex-1 text-sm #{task.done? ? 'line-through text-gray-400' : 'text-gray-700 hover:text-indigo-600'} transition-colors truncate" %>

            <div class="flex items-center gap-2 shrink-0">
              <% if task.channel %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>"><%= task.channel.name %></span>
              <% end %>
              <% if task.scheduled_date %>
                <span class="text-[10px] text-gray-400"><%= task.scheduled_date.strftime("%a %-d") %></span>
              <% else %>
                <span class="text-[10px] text-gray-300 italic">Backlog</span>
              <% end %>
              <% if task.actual_minutes > 0 %>
                <span class="text-[10px] text-gray-400 tabular-nums"><%= task.actual_minutes %>m</span>
              <% end %>

              <!-- Unlink button -->
              <%= button_to unlink_task_weekly_objective_path(@objective, task_id: task.id), method: :post,
                  class: "hidden group-hover:block p-1 rounded hover:bg-red-50 transition-colors", title: "Unlink from objective" do %>
                <svg class="w-3.5 h-3.5 text-gray-400 hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center">
        <p class="text-sm text-gray-400">No tasks linked yet. Add tasks below.</p>
      </div>
    <% end %>
  </div>

  <!-- Link existing tasks -->
  <% if @available_tasks.any? %>
    <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Add tasks to this objective</h3>
      </div>
      <div class="divide-y divide-gray-50 max-h-64 overflow-y-auto">
        <% @available_tasks.each do |task| %>
          <div class="flex items-center gap-3 px-5 py-2.5 hover:bg-indigo-50/50 transition-colors">
            <%= button_to link_task_weekly_objective_path(@objective, task_id: task.id), method: :post,
                class: "p-1 rounded hover:bg-indigo-100 transition-colors shrink-0", title: "Link to objective" do %>
              <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
            <% end %>
            <span class="text-sm text-gray-600 truncate"><%= task.title %></span>
            <% if task.channel %>
              <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full ml-auto shrink-0" style="background-color: <%= task.channel.color %>15; color: <%= task.channel.color %>"><%= task.channel.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
