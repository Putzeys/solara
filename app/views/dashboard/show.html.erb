<div class="flex flex-col lg:flex-row gap-4 lg:gap-6 h-full">
  <!-- Task List (left panel) -->
  <div class="w-full lg:w-1/2 flex flex-col min-w-0">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Tasks</h2>
      <% remaining = @tasks.not_done.count %>
      <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= remaining > 0 ? 'bg-indigo-50 text-indigo-600' : 'bg-emerald-50 text-emerald-600' %>">
        <%= remaining > 0 ? "#{remaining} remaining" : "All done!" %>
      </span>
    </div>

    <!-- Quick add -->
    <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm px-4 py-3 mb-3">
      <%= render "tasks/quick_add" %>
    </div>

    <!-- Task list -->
    <div id="tasks_container" class="bg-white rounded-xl border border-gray-200/60 shadow-sm divide-y divide-gray-100 overflow-hidden"
         data-controller="sortable" data-sortable-url-value="<%= reorder_tasks_path %>">
        <% @tasks.each do |task| %>
          <%= render "tasks/task", task: task %>
        <% end %>

        <% if @tasks.empty? %>
          <div class="text-center py-12 px-4">
            <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/></svg>
            </div>
            <p class="text-sm font-medium text-gray-500">No tasks for today</p>
            <p class="text-xs text-gray-400 mt-1">Add one above or start your morning planning</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Backlog preview -->
    <% if @backlog_tasks.any? %>
      <div class="mt-5">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Backlog</h3>
          <%= link_to "View all", backlog_path, class: "text-xs font-medium text-indigo-500 hover:text-indigo-700 transition-colors" %>
        </div>
        <div class="bg-white/60 rounded-xl border border-gray-200/40 shadow-sm divide-y divide-gray-50 overflow-hidden">
          <% @backlog_tasks.first(5).each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Calendar Timeline (right panel) -->
  <div class="w-full lg:w-1/2 bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden flex flex-col" data-controller="calendar-timeline">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between shrink-0">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Timeline</h2>
      <span class="text-xs text-gray-400"><%= @calendar_events.count + @working_sessions.count %> events</span>
    </div>

    <div class="flex-1 overflow-y-auto p-3">
      <div class="relative">
        <% (7..22).each do |hour| %>
          <% hour_events = @calendar_events.select { |e| e.starts_at.hour == hour } %>
          <% hour_sessions = @working_sessions.select { |ws| ws.starts_at.hour == hour } %>
          <div class="flex items-start border-t border-gray-50 min-h-[3.5rem] group" data-hour="<%= hour %>">
            <span class="w-12 text-[11px] font-medium text-gray-300 py-2 shrink-0 group-hover:text-gray-500 transition-colors">
              <%= "#{hour.to_s.rjust(2, '0')}:00" %>
            </span>
            <div class="flex-1 py-1.5 pl-2 space-y-1.5">
              <% hour_events.each do |event| %>
                <div class="text-xs bg-blue-50 text-blue-700 rounded-lg px-3 py-2 border-l-[3px] border-blue-400 shadow-sm">
                  <span class="font-medium"><%= event.title %></span>
                  <span class="text-blue-400 ml-1.5"><%= event.starts_at.strftime("%-H:%M") %>&ndash;<%= event.ends_at.strftime("%-H:%M") %></span>
                </div>
              <% end %>
              <% hour_sessions.each do |session| %>
                <div class="text-xs bg-indigo-50 text-indigo-700 rounded-lg px-3 py-2 border-l-[3px] border-indigo-400 shadow-sm">
                  <span class="font-medium"><%= session.task.title %></span>
                  <span class="text-indigo-400 ml-1.5"><%= session.duration_minutes %>m</span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
