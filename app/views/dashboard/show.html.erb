<div class="flex flex-col lg:flex-row gap-4 lg:gap-6 h-[calc(100vh-5rem)]">
  <!-- Task List (left panel) -->
  <div class="w-full lg:w-1/2 flex flex-col min-w-0 min-h-0">
    <div class="flex items-center justify-between mb-3 shrink-0">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Tasks</h2>
      <% remaining = @tasks.not_done.count %>
      <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= remaining > 0 ? 'bg-indigo-50 text-indigo-600' : 'bg-emerald-50 text-emerald-600' %>">
        <%= remaining > 0 ? "#{remaining} remaining" : "All done!" %>
      </span>
    </div>

    <!-- Quick add -->
    <div class="bg-white rounded-xl border border-gray-200/60 shadow-sm px-4 py-3 mb-3 shrink-0">
      <%= render "tasks/quick_add" %>
    </div>

    <!-- Task list -->
    <div id="tasks_container" class="bg-white rounded-xl border border-gray-200/60 shadow-sm divide-y divide-gray-100 overflow-y-auto flex-1 min-h-0"
         data-controller="sortable" data-sortable-url-value="<%= reorder_tasks_path %>">
        <% @tasks.each do |task| %>
          <%= render "tasks/task", task: task %>
        <% end %>

        <% if @tasks.empty? %>
          <div id="empty_tasks_state" class="text-center py-12 px-4">
            <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/></svg>
            </div>
            <p class="text-sm font-medium text-gray-500">No tasks for today</p>
            <p class="text-xs text-gray-400 mt-1">Add one above or start your morning planning</p>
          </div>
        <% end %>
      </div>

    <!-- Backlog preview -->
    <% if @backlog_tasks.any? %>
      <div class="mt-5">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Backlog</h3>
          <%= link_to "View all", backlog_path, class: "text-xs font-medium text-indigo-500 hover:text-indigo-700 transition-colors" %>
        </div>
        <div class="bg-white/60 rounded-xl border border-gray-200/40 shadow-sm divide-y divide-gray-50 overflow-hidden">
          <% @backlog_tasks.first(5).each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Calendar Timeline (right panel) -->
  <div class="w-full lg:w-1/2 min-h-[60vh] lg:min-h-0 bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden flex flex-col"
       data-controller="calendar-timeline event-popup"
       <% if @active_timer %>
         data-calendar-timeline-active-timer-value="<%= { task_title: @active_timer.task.title, started_at: @active_timer.started_at.iso8601 }.to_json %>"
       <% end %>>
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between shrink-0">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Timeline</h2>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-400"><%= @calendar_events.count + @working_sessions.count %> events</span>
        <button type="button" data-action="click->event-popup#toggleFilters" class="p-1 rounded hover:bg-gray-100 transition-colors" title="Filter calendars">
          <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
        </button>
      </div>
    </div>

    <!-- Calendar filters panel -->
    <div data-event-popup-target="filters" class="hidden border-b border-gray-100 px-4 py-3 bg-gray-50/50 space-y-2 max-h-48 overflow-y-auto shrink-0">
      <p class="text-[11px] font-semibold text-gray-400 uppercase tracking-widest mb-1">Calendars</p>
      <% @integrations.each do |integration| %>
        <% (integration.calendar_metadata || {}).each do |cal_id, meta| %>
          <% hidden = (integration.hidden_calendar_ids || []).include?(cal_id) %>
          <%= button_to toggle_calendar_path(integration, calendar_id: cal_id), method: :post, class: "flex items-center gap-2 w-full text-left group/filter" do %>
            <div class="w-3 h-3 rounded-sm border shrink-0 <%= hidden ? 'border-gray-300 bg-white' : 'border-transparent' %>"
                 style="<%= hidden ? '' : "background-color: #{meta['color'] || '#4285F4'}" %>"></div>
            <span class="text-xs truncate <%= hidden ? 'text-gray-400 line-through' : 'text-gray-700' %>"><%= meta["summary"] || cal_id %></span>
            <span class="text-[10px] text-gray-300 ml-auto shrink-0"><%= integration.google_email %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="flex-1 overflow-y-auto p-3">
      <div class="relative">
        <% (7..22).each do |hour| %>
          <% hour_events = @calendar_events.select { |e| e.starts_at.hour == hour } %>
          <% hour_sessions = @working_sessions.select { |ws| ws.starts_at.hour == hour } %>
          <div class="flex items-start border-t border-gray-50 min-h-[3.5rem] group" data-hour="<%= hour %>">
            <span class="w-12 text-[11px] font-medium text-gray-300 py-2 shrink-0 group-hover:text-gray-500 transition-colors">
              <%= "#{hour.to_s.rjust(2, '0')}:00" %>
            </span>
            <div class="flex-1 py-1.5 pl-2 space-y-1.5">
              <% hour_events.each do |event| %>
                <% cal_meta = @calendar_lookup[event.google_calendar_id] || {} %>
                <% cal_color = cal_meta["color"] || "#4285F4" %>
                <div class="text-xs rounded-lg px-3 py-2 border-l-[3px] shadow-sm cursor-pointer hover:shadow-md transition-shadow"
                     style="background-color: <%= cal_color %>10; color: <%= cal_color %>; border-color: <%= cal_color %>"
                     data-action="click->event-popup#show"
                     data-event-title="<%= event.title %>"
                     data-event-time="<%= event.starts_at.strftime("%-H:%M") %> &ndash; <%= event.ends_at.strftime("%-H:%M") %>"
                     data-event-calendar="<%= cal_meta['summary'] || event.google_calendar_id %>"
                     data-event-calendar-color="<%= cal_color %>"
                     data-event-description="<%= event.description %>"
                     data-event-location="<%= event.location %>"
                     data-event-attendees="<%= (event.attendees || []).map { |a| a['name'] || a['email'] }.join(', ') %>"
                     data-event-link="<%= event.html_link %>"
                     data-event-account="<%= cal_meta['google_email'] %>">
                  <div class="flex items-center gap-1.5">
                    <span class="font-medium" style="color: inherit"><%= event.title %></span>
                    <span class="opacity-60 ml-auto text-[10px] shrink-0"><%= event.starts_at.strftime("%-H:%M") %>&ndash;<%= event.ends_at.strftime("%-H:%M") %></span>
                  </div>
                  <% if cal_meta["summary"] %>
                    <p class="opacity-50 text-[10px] mt-0.5"><%= cal_meta["summary"] %></p>
                  <% end %>
                </div>
              <% end %>
              <% hour_sessions.each do |session| %>
                <div class="text-xs bg-indigo-50 text-indigo-700 rounded-lg px-3 py-2 border-l-[3px] border-indigo-400 shadow-sm">
                  <span class="font-medium"><%= session.task.title %></span>
                  <span class="text-indigo-400 ml-1.5"><%= session.starts_at.strftime("%-H:%M") %>&ndash;<%= session.ends_at.strftime("%-H:%M") %></span>
                  <span class="text-indigo-300 ml-1">(<%= session.duration_minutes %>m)</span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <% if @working_sessions.any? %>
      <div class="px-4 py-2 border-t border-gray-100 shrink-0">
        <p class="text-[11px] text-gray-400">
          Total: <%= @working_sessions.sum(&:duration_minutes) %>m worked today
        </p>
      </div>
    <% end %>

    <!-- Event detail popup -->
    <div data-event-popup-target="popup" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" data-action="click->event-popup#hide">
      <div class="absolute inset-0 bg-black/20"></div>
      <div class="relative bg-white rounded-xl shadow-xl max-w-sm w-full p-5 space-y-3" data-action="click->event-popup#stopPropagation">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-sm shrink-0" data-event-popup-target="colorDot"></div>
            <h3 class="font-semibold text-gray-900 text-sm" data-event-popup-target="title"></h3>
          </div>
          <button type="button" data-action="click->event-popup#hide" class="text-gray-400 hover:text-gray-600 -mt-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="space-y-2 text-xs text-gray-600">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span data-event-popup-target="time"></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span data-event-popup-target="calendar"></span>
          </div>
          <div data-event-popup-target="locationRow" class="flex items-start gap-2 hidden">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span data-event-popup-target="location"></span>
          </div>
          <div data-event-popup-target="attendeesRow" class="flex items-start gap-2 hidden">
            <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span data-event-popup-target="attendees" class="leading-relaxed"></span>
          </div>
          <div data-event-popup-target="descriptionRow" class="hidden pt-2 border-t border-gray-100">
            <p data-event-popup-target="description" class="text-xs text-gray-500 whitespace-pre-wrap leading-relaxed"></p>
          </div>
          <div data-event-popup-target="accountRow" class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span data-event-popup-target="account" class="text-gray-400"></span>
          </div>
        </div>

        <div data-event-popup-target="linkRow" class="hidden pt-2">
          <a data-event-popup-target="link" href="#" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600 hover:text-blue-800 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Open in Google Calendar
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
