<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-4">
    <span class="w-3 h-3 rounded-full" style="background-color: <%= @channel.color %>"></span>
    <h2 class="text-lg font-semibold text-gray-900"><%= @channel.name %></h2>
    <span class="text-sm text-gray-500">(<%= @tasks.count %> tasks)</span>
  </div>

  <div class="space-y-1">
    <% @tasks.each do |task| %>
      <%= render "tasks/task", task: task %>
    <% end %>

    <% if @tasks.empty? %>
      <p class="text-sm text-gray-400 py-4 text-center">No tasks in this channel</p>
    <% end %>
  </div>
</div>
