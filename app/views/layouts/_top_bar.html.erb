<header class="bg-white/80 backdrop-blur-sm border-b border-gray-200/60 px-4 py-3 flex items-center justify-between shrink-0 sticky top-0 z-10">
  <div class="flex items-center gap-2 sm:gap-3">
    <!-- Mobile hamburger -->
    <button class="lg:hidden p-1.5 -ml-1 rounded-lg hover:bg-gray-100 text-gray-500 transition-colors" data-action="click->sidebar#toggle">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>

    <!-- Date navigation -->
    <%= link_to day_path(date: current_date - 1), class: "p-1.5 rounded-lg hover:bg-gray-100 transition-colors" do %>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>

    <h1 class="text-base sm:text-lg font-semibold text-gray-900 whitespace-nowrap">
      <% if current_date == Date.current %>
        <span class="hidden sm:inline">Today &middot; </span><%= current_date.strftime("%a, %b %-d") %>
      <% elsif current_date == Date.current + 1 %>
        <span class="hidden sm:inline">Tomorrow &middot; </span><%= current_date.strftime("%a, %b %-d") %>
      <% elsif current_date == Date.current - 1 %>
        <span class="hidden sm:inline">Yesterday &middot; </span><%= current_date.strftime("%a, %b %-d") %>
      <% else %>
        <%= current_date.strftime("%a, %b %-d") %><span class="hidden sm:inline">, <%= current_date.strftime("%Y") %></span>
      <% end %>
    </h1>

    <%= link_to day_path(date: current_date + 1), class: "p-1.5 rounded-lg hover:bg-gray-100 transition-colors" do %>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>

    <% unless current_date == Date.current %>
      <%= link_to "Today", root_path, class: "ml-1 text-xs sm:text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-colors" %>
    <% end %>
  </div>

  <div class="flex items-center gap-1.5 sm:gap-2">
    <!-- Workload indicator -->
    <% planned = @tasks&.sum(:planned_minutes) || 0 %>
    <% target = current_user.daily_hour_target %>
    <% workload_pct = target > 0 ? (planned.to_f / target * 100).round : 0 %>
    <div class="hidden sm:flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium
                <%= workload_pct > 100 ? 'bg-red-50 text-red-600' : workload_pct > 80 ? 'bg-amber-50 text-amber-600' : 'bg-gray-100 text-gray-500' %>">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-width="1.5" d="M12 6v6l4 2"/></svg>
      <%= planned / 60 %>h<%= "%02d" % (planned % 60) %>m / <%= target / 60 %>h
    </div>

    <!-- Morning Planning -->
    <%= link_to morning_plan_path(date: current_date),
        class: "inline-flex items-center gap-1.5 px-2.5 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-lg bg-amber-50 text-amber-700 hover:bg-amber-100 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/></svg>
      <span class="hidden sm:inline">Plan</span>
    <% end %>

    <!-- Shutdown -->
    <%= link_to shutdown_plan_path(date: current_date),
        class: "inline-flex items-center gap-1.5 px-2.5 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-lg bg-violet-50 text-violet-700 hover:bg-violet-100 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      <span class="hidden sm:inline">Shutdown</span>
    <% end %>

    <!-- New task -->
    <%= link_to new_task_path,
        class: "inline-flex items-center gap-1.5 px-2.5 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm shadow-indigo-200 transition-all hover:shadow-md hover:shadow-indigo-200" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <span class="hidden sm:inline">New Task</span>
    <% end %>
  </div>
</header>
